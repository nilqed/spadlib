)co ../src/space3.spad

DF ==> DoubleFloat
LDF ==> List DF

s:=makeObject(x*y,x=-1..1,y=-2..2,[])

lps:=lp s

pts:=[[u.1,u.2,u.3] for u in lps]

sgle:=mkSGLE("/tmp/testsgle",16,16,pts)


testSGLE(s:String):Void == 
  writeToFile(s,"/tmp/testsgle.gle")
  systemCommand "system qgle /tmp/testsgle.gle"
  
-- test it!  
testSGLE sgle

--> use 'edit testsgle.gle' in the QGLE menu
--> add top and underneath color ..... and so on
--> save -> it will automatically update
-- 
--begin fitz
--data "/tmp/testsgle.dat"
--x from -1.0 to 1.0 step 0.2
--y from -2.0 to 2.0 step 0.2
--ncontour 10
--end fitz

--begin surface
--size 16 16
--data "/tmp/testsgle.z"
--top color blue
--underneath color orange
--end surface
